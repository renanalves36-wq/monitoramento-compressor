FLOW_SATURATION_VAPOR_PRESSURE_KPA=3.7831
FLOW_CURRENT_TO_NORMAL_FACTOR=0.87658
FLOW_NOMINAL_NM3H=12000
FLOW_NOMINAL_CURRENT_A=180
FLOW_NO_LOAD_CURRENT_A=0
