APP_NAME=ta6000-monitor
ENVIRONMENT=local
LOG_LEVEL=INFO
DATA_SOURCE_MODE=auto

SQL_SERVER=srv01win185
SQL_PORT=1433
SQL_DATABASE=INDUSOFT
SQL_USERNAME=
SQL_PASSWORD=
SQL_CONNECTION_STRING=
SQL_ENCRYPT=Optional
SQL_TRUST_SERVER_CERTIFICATE=yes

INITIAL_LOOKBACK_HOURS=24
CACHE_TTL_SECONDS=60
API_READINGS_LIMIT=50
DEMO_CSV_CHUNK_SIZE=20000
DEMO_CSV_BOOTSTRAP_ROWS=5000
DEMO_CSV_FULL_BOOTSTRAP=true
