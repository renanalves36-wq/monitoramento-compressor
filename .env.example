PREDICTIVE_FORECAST_HORIZON_MINUTES=180
PREDICTIVE_TRIP_HORIZON_MINUTES=45
PREDICTIVE_MIN_POINTS=18
PREDICTIVE_MIN_REGRESSION_R2=0.55
FLOW_SUCTION_TEMPERATURE_C=28
FLOW_SUCTION_RELATIVE_HUMIDITY_PCT=90
